{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!**/dist", "!**/node_modules", "!**/*.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "noAssignInExpressions": "off",
        "noGlobalIsNan": "warn",
        "noImplicitAnyLet": "warn",
        "noThenProperty": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noUselessConstructor": "off",
        "noStaticOnlyClass": "off"
      },
      "style": {
        "noParameterAssign": "off",
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "useTemplate": "off",
        "useImportType": "warn",
        "noUselessElse": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "warn"
      },
      "performance": {
        "noDelete": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "overrides": [
    {
      "includes": ["**/tests/**", "**/__tests__/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "useYield": "off"
          },
          "suspicious": {
            "noImplicitAnyLet": "off"
          }
        }
      }
    }
  ]
}
